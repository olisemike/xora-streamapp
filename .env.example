# StreamVibe Environment Variables
# Copy this file to .env and fill in your values

# ===========================
# DEVELOPMENT
# ===========================
API_URL=http://localhost:8787
NODE_ENV=development

# ===========================
# ADMIN
# ===========================
ADMIN_KEY=your-admin-key-here
ADMIN_EMAIL=olisemike9@gmail.com

# ===========================
# CLOUDFLARE
# ===========================
CF_ACCOUNT_ID=7fe26552990070e661d5f182566d039f
CF_API_TOKEN=your-cloudflare-api-token-here

# Cloudflare Images
CLOUDFLARE_IMAGES_HASH=1eL4FEtJQavAd5JjFtJe7Q
CLOUDFLARE_IMAGES_DELIVERY_URL=https://imagedelivery.net/1eL4FEtJQavAd5JjFtJe7Q

# Cloudflare Stream
CLOUDFLARE_STREAM_SUBDOMAIN=customer-virwr1ukt49zj3yu.cloudflarestream.com

# ===========================
# MEDIA
# ===========================
MEDIA_PER_PAGE=30
MAX_UPLOAD_SIZE=536870912

# ===========================
# ADVERTISING (Easy Copy-Paste)
# ===========================
# METHOD 1: Paste codes directly in src/index.js (RECOMMENDED)
# Just find <!-- PASTE AD CODE HERE --> and replace with your code

# METHOD 2: Use environment variables (Optional)
# Paste your full ad codes here if you prefer
# Then reference them in getAppJS() and getWatchJS()
# NOTE: Large codes may not work well in env variables

AD_HOME_TOP_CODE=
AD_HOME_MIDDLE_CODE=
AD_HOME_BOTTOM_CODE=
AD_WATCH_TOP_CODE=
AD_WATCH_MIDDLE_CODE=
AD_WATCH_BOTTOM_CODE=
AD_VIDEO_CODE=

# ===========================
# CORS & SECURITY
# ===========================
CORS_ORIGINS=http://localhost:8787,http://localhost:3000

# ===========================
# ANALYTICS
# ===========================
ANALYTICS_ENABLED=true
TRACK_VIEWS=true
TRACK_DOWNLOADS=true

# ===========================
# CACHE
# ===========================
CACHE_ENABLED=true
CACHE_TTL_MEDIA=3600
CACHE_TTL_METADATA=1800
CACHE_TTL_ADS=600

